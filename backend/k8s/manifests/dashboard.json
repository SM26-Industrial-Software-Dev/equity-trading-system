{
  "title": "k3d Stats",
  "uid": "9mfU3p-vk",
  "schemaVersion": 34,
  "refresh": "5s",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "FastAPI Hardware Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Active FastAPI Nodes",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "instant": true,
          "expr": "max(kube_deployment_status_replicas_available{deployment=\"fastapi-api\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total CPU Utilization (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(irate(container_cpu_usage_seconds_total{container=\"fastapi\"}[2m])) / (max(kube_deployment_status_replicas_available{deployment=\"fastapi-api\"}) * 0.1)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage per Pod (Cores)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(irate(container_cpu_usage_seconds_total{container=\"fastapi\"}[2m])) by (pod)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "FastAPI HTTP Traffic (/metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 201,
      "title": "Requests Per Second (Throughput)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"fastapi-service\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 202,
      "title": "HTTP Error Rate (4xx & 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"fastapi-service\", status=~\"[45].*\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 203,
      "title": "P95 Response Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"fastapi-service\"}[1m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Database Live Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
