      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 12,
      "options": {
        "showTime": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{app=\"Streamlit\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "FastAPI Path Live Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 13,
      "options": {
