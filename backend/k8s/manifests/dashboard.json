      "collapsed": false
    },
    {
      "id": 6,
      "title": "FastAPI Live Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 37 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "options": {
        "showTime": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{app=\"fastapi\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
